{
	"name": "backend",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"check": "biome check .",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"db:migrate": "tsx src/migrate.ts",
		"dev": "tsx watch src/server.ts",
		"format": "biome format .",
		"lint": "biome check .",
		"start": "node dist/server.js",
		"test": "bun test --pass-with-no-tests"
	},
	"dependencies": {
		"@fastify/websocket": "^11.3.0",
		"@payproof/celo": "workspace:*",
		"@payproof/domain": "workspace:*",
		"dotenv": "^17.2.3",
		"fastify": "^5.10.0",
		"pg": "^8.20.0",
		"redis": "^5.10.0",
		"viem": "2.55.4",
		"zod": "^4.1.11"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@types/node": "^24.13.3",
		"@types/pg": "^8.16.0",
		"tsx": "^4.23.1",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=24.13.0"
	}
}
